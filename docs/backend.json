
{
  "entities": {
    "Manufacturer": {
      "title": "Manufacturer",
      "description": "Details of a product manufacturer",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "ManufacturerFile": {
      "title": "Manufacturer File",
      "description": "Technical or pricing document",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "manufacturer_id": { "type": "string", "format": "uuid" },
        "file_type": { "type": "string", "enum": ["spec", "pricing"] },
        "file_name": { "type": "string" },
        "file_url": { "type": "string" },
        "file_format": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "ManufacturerSpecification": {
      "title": "Manufacturer Specification",
      "description": "Extracted cabinet specifications",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "manufacturer_id": { "type": "string", "format": "uuid" },
        "collection_name": { "type": "string" },
        "door_style": { "type": "string" },
        "finish": { "type": "string" },
        "category": { "type": "string" },
        "raw_source_file_id": { "type": "string", "format": "uuid" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "NkbaRule": {
      "title": "NKBA Rule",
      "description": "Official NKBA standards document",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "version": { "type": "string" },
        "file_name": { "type": "string" },
        "file_url": { "type": "string" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/manufacturers/{id}": { "schema": "Manufacturer" },
    "/manufacturer_files/{id}": { "schema": "ManufacturerFile" },
    "/manufacturer_specifications/{id}": { "schema": "ManufacturerSpecification" },
    "/nkba_rules/{id}": { "schema": "NkbaRule" }
  }
}
