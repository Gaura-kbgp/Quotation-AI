
# -----------------------------------------------------------------------------
# KABS QUOTATION AI - ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in your actual production keys.
# -----------------------------------------------------------------------------

# NEXTJS / APP
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app-name.onrender.com

# GENKIT / AI (Gemini 2.0 Flash)
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# SUPABASE (Database & Storage)
# Use NEXT_PUBLIC_ for client-side, and just SUPABASE_ for server-side
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_private_service_role_key_here

# FIREBASE (Auth & Static Config)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
